translate_state_name <- function(x){
    v1 <- c(
        state.name, "District of Columbia", "Puerto Rico", "U.S. Island Areas")
    names(v1) <- c(state.abb, "DC", "PR", "USISLAND")
    
    if_else(is.na(v1[x]), x, v1[x])
}

