data_col_names_2024_1 <- c("state", "var", "estimate", "moe")
data_col_names_2024_2 <- c(
    "state",
    "popover1",
    "popover1_moe",
    "samehouse",
    "samehouse_moe",
    "samestate",
    "samestate_moe",
